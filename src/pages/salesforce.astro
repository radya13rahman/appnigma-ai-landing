---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import SocialProof from '../components/SocialProof.astro';
import Testimonial from '../components/Testimonial.astro';
import Stats from '../components/Stats.astro';
import FinalCTA from '../components/FinalCTA.astro';
import Compare from '../components/Compare.astro';
import Footer from '../components/Footer.astro';
---
<Layout title="Salesforce Native Managed Packages — Appnigma AI">
  <Header />

  <!-- Hero -->
  <section class="hero-section relative bg-white overflow-hidden" style="min-height:836px;">
    <div class="absolute inset-0 pointer-events-none">
      <img src="/assets/75195996e7c99093b024e02f4d0267a71c585ef6.png" alt="" class="hero-bg-img absolute inset-0 w-full h-full object-cover object-bottom" fetchpriority="high" />
      <div class="hero-bg-overlay absolute inset-0" style="background:linear-gradient(180deg,rgba(255,255,255,1) 14%,rgba(255,255,255,0) 24.28%),linear-gradient(rgba(255,255,255,0) 51.92%,rgba(255,255,255,1) 94.71%)"></div>
    </div>
    <div class="hero-left-gradient absolute left-0 top-0 h-full pointer-events-none" style="width:893px;background:linear-gradient(to right,white 65.38%,transparent 100%);"></div>
    <div class="hero-content px-section relative max-w-[1440px] mx-auto flex items-center" style="padding-left:120px;padding-right:120px;min-height:836px;padding-top:143px;padding-bottom:80px;">
      <div class="flex flex-col gap-16 w-[591px] max-w-full">
        <div class="flex flex-col gap-6">
          <h1 class="hero-h1 font-heading font-medium text-[#0a0a0a] leading-[1.1]" style="font-size:64px;letter-spacing:-1.2px;">
            From spec to<br />AppExchange.<br />In minutes.
          </h1>
          <p class="font-body font-normal text-[16px] text-[#525252] leading-[1.5]" style="max-width:591px;">
            Appnigma AI generates Apex, LWC, and metadata for a managed package that's structured for Security Review — no AppExchange consultant required.
          </p>
          <div class="flex items-center gap-2">
            <button class="btn-primary font-body font-medium text-[14px] text-white px-3 h-9 rounded-[8px] whitespace-nowrap" style="letter-spacing:-0.14px;">Book a demo</button>
            <button class="btn-secondary font-body font-medium text-[14px] text-[#1d2b31] px-3 h-9 rounded-[8px] whitespace-nowrap" style="letter-spacing:-0.14px;">Learn More</button>
          </div>
        </div>
        <div class="flex flex-col gap-2">
          <div class="flex flex-col overflow-hidden py-4">
            <div class="flex items-center gap-6">
              <div class="flex items-center">
                <div class="w-12 h-12 rounded-full border-[0.96px] border-white overflow-hidden -mr-4 relative z-10" style="background:linear-gradient(to bottom,#d1d1d1,#f9f9f9);">
                  <img src="/assets/39921c6e1a55ece00506afb87e09ce5a1f14650b.png" alt="" class="w-full h-full object-cover" />
                </div>
                <div class="w-12 h-12 rounded-full border-[0.96px] border-white overflow-hidden relative" style="background:linear-gradient(to bottom,#d1d1d1,#f9f9f9);">
                  <img src="/assets/ef10b07ee57f3b66d85380bf095ffc6d8e2ac0a0.png" alt="" class="w-full h-full object-cover" />
                </div>
              </div>
              <div class="flex flex-col">
                <span class="font-body font-semibold text-[16px] text-[#525252] leading-[1.1]">Built by ex-Salesforce AppExchange engineers</span>
                <span class="font-body font-normal text-[16px] text-[#525252] leading-[1.5]">300+ SaaS integrations shipped</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Social Proof Logo Band -->
  <SocialProof />

  <!-- Why Appnigma for Salesforce (dark) -->
  <section class="sf-why-section bg-[#151515] px-section relative mx-auto max-w-[1440px] flex-shrink-0 flex flex-col items-start gap-[8px]" style="padding-left:120px;padding-right:120px;height:740px;box-sizing:border-box;">
    <div class="sf-why-row border-l border-r border-[#3d3d3d] flex flex-row items-start gap-0" style="width:1200px;height:740px;padding:80px 0px;box-sizing:border-box;background:#151515;">
      <!-- Left: text + features -->
      <div class="sf-why-left flex flex-col border-t border-b border-[#3d3d3d] flex-shrink-0" style="width:600px;height:580px;box-sizing:border-box;">
        <!-- Heading block -->
        <div class="flex flex-col gap-[16px] p-[24px] flex-shrink-0" style="width:600px;height:302px;box-sizing:border-box;">
          <div class="flex flex-row justify-center items-center gap-[8px] bg-[rgba(255,255,255,0.05)] border border-[rgba(255,255,255,0.05)] rounded-none" style="width:203px;height:34px;flex:none;order:0;flex-grow:0;box-sizing:border-box;">
            <span class="font-body font-normal text-[12px] text-[rgba(255,255,255,0.5)] leading-[1.5]" style="font-family:'Montserrat', sans-serif;">Why Appnigma for Salesforce</span>
          </div>
          <div class="flex flex-row items-start p-0 gap-[8px]" style="width:552px;height:70px;flex:none;order:1;align-self:stretch;flex-grow:0;box-sizing:border-box;">
            <h2 class="font-heading font-medium text-white text-[32px] leading-[110%] flex-grow" style="font-family:'Space Grotesk', sans-serif; letter-spacing:-1.2px;">Native by default.<br />Generated by design.</h2>
          </div>
          <div class="flex flex-row items-center p-0 gap-[8px]" style="width:552px;height:72px;flex:none;order:2;align-self:stretch;flex-grow:0;box-sizing:border-box;">
            <p class="font-body font-normal text-[16px] text-[rgba(255,255,255,0.5)] leading-[150%] flex-grow" style="width:552px;height:72px;font-family:'Montserrat', sans-serif;">
              One workflow that replaces a six-month consulting engagement.
            </p>
          </div>
        </div>

        <!-- Feature: Days, not months -->
        <div class="sf-feature-btn flex items-start gap-[16px] p-[24px] border-t border-b border-[#3D3D3D] cursor-pointer transition-all duration-300" data-index="0" style="width:600px;height:118px;background-color:#262626;flex:none;order:1;align-self:stretch;flex-grow:0;box-sizing:border-box;">
          <div class="sf-feature-icon-box flex-shrink-0 w-8 h-8 border border-[rgba(255,255,255,0.1)] bg-[rgba(255,255,255,0.05)] flex items-center justify-center transition-all duration-300">
            <svg class="sf-feature-icon text-white transition-colors duration-300" width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M9 1L3 9h5l-1 6 6-8H8l1-6z"/></svg>
          </div>
          <div class="sf-feature-text-wrap flex flex-col gap-[10px] flex-grow" style="width:504px;height:70px;box-sizing:border-box;">
            <span class="font-body font-semibold text-[16px] text-white leading-[110%] h-[18px]" style="font-family:'Montserrat', sans-serif;">Days, not months</span>
            <div class="sf-feature-desc transition-all duration-300 overflow-hidden" style="max-height: 42px; opacity: 1;">
              <p class="font-body font-normal text-[14px] text-[rgba(255,255,255,0.5)] leading-[150%] w-[504px] h-[42px] mt-1" style="font-family:'Montserrat', sans-serif;">Describe the package — objects, flows, Lightning components.</p>
            </div>
          </div>
        </div>

        <!-- Feature: You own the package -->
        <div class="sf-feature-btn flex items-start gap-[16px] p-[24px] border-b border-[#3D3D3D] cursor-pointer transition-all duration-300" data-index="1" style="width:600px;height:80px;background-color:#151515;flex:none;order:2;align-self:stretch;flex-grow:0;box-sizing:border-box;">
          <div class="sf-feature-icon-box flex-shrink-0 w-8 h-8 border border-[rgba(255,255,255,0.1)] bg-[rgba(255,255,255,0.05)] flex items-center justify-center transition-all duration-300">
            <svg class="sf-feature-icon text-[rgba(255,255,255,0.2)] transition-colors duration-300" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line></svg>
          </div>
          <div class="sf-feature-text-wrap flex flex-col gap-[10px] flex-grow" style="width:504px;height:18px;box-sizing:border-box;">
            <span class="font-body font-semibold text-[16px] text-white leading-[110%] h-[18px]" style="font-family:'Montserrat', sans-serif;">You own the package</span>
            <div class="sf-feature-desc transition-all duration-300 overflow-hidden" style="max-height: 0px; opacity: 0;">
              <p class="font-body font-normal text-[14px] text-[rgba(255,255,255,0.5)] leading-[150%] w-[504px] h-[42px] mt-1" style="font-family:'Montserrat', sans-serif;">Generated Apex, LWC, and metadata are yours. No namespace lock-in, no service contract, no perpetual retainer.</p>
            </div>
          </div>
        </div>

        <!-- Feature: Security Review, embedded -->
        <div class="sf-feature-btn flex items-start gap-[16px] p-[24px] cursor-pointer transition-all duration-300" data-index="2" style="width:600px;height:80px;background-color:#151515;flex:none;order:3;align-self:stretch;flex-grow:0;box-sizing:border-box;">
          <div class="sf-feature-icon-box flex-shrink-0 w-8 h-8 border border-[rgba(255,255,255,0.1)] bg-[rgba(255,255,255,0.05)] flex items-center justify-center transition-all duration-300">
            <svg class="sf-feature-icon text-[rgba(255,255,255,0.2)] transition-colors duration-300" width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><rect x="3" y="7" width="10" height="7" rx="1"/><path d="M5 7V5a3 3 0 0 1 6 0v2"/></svg>
          </div>
          <div class="sf-feature-text-wrap flex flex-col gap-[10px] flex-grow" style="width:504px;height:18px;box-sizing:border-box;">
            <span class="font-body font-semibold text-[16px] text-white leading-[110%] h-[18px]" style="font-family:'Montserrat', sans-serif;">Security Review, embedded</span>
            <div class="sf-feature-desc transition-all duration-300 overflow-hidden" style="max-height: 0px; opacity: 0;">
              <p class="font-body font-normal text-[14px] text-[rgba(255,255,255,0.5)] leading-[150%] w-[504px] h-[42px] mt-1" style="font-family:'Montserrat', sans-serif;">AppExchange best practices baked into every artifact — 0 PMD violations, ApexGuru-checked, 90%+ test coverage.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: mock UI viewport -->
      <div class="sf-why-right sf-why-right-viewport relative flex-shrink-0 flex flex-col items-center justify-start overflow-hidden" style="width:600px;height:580px;background:#1B1B1B;border:1px solid #333333;box-sizing:border-box;">
        <!-- Background hatch pattern -->
        <div class="absolute inset-0 overflow-hidden">
          <div class="absolute inset-0 sf-hatch-pattern"></div>
        </div>

        <!-- Vertical Sliding Container -->
        <div class="sf-why-mock-track relative flex flex-col items-center gap-40 w-[400px] max-w-full transition-transform duration-500 ease-in-out">
          <!-- Mac Mockup Window 1: Prompt Screenshot -->
          <div class="sf-mockup-window relative w-[400px] max-w-full bg-[#262626] rounded-[9.30233px] overflow-hidden shadow-2xl flex flex-col flex-shrink-0 transition-opacity duration-300">
            <!-- Mac Window Header -->
            <div class="flex flex-row justify-between items-center bg-[#1a1a1a] flex-shrink-0" style="width:400px;height:27.91px;padding:9.30233px 0px;z-index:1;box-sizing:border-box;">
              <!-- Traffic lights container -->
              <div class="flex flex-row align-items-center gap-[3.1px]" style="width:48.06px;min-width:48.06px;height:6.2px;margin:0 auto;padding-left:9.30233px;box-sizing:border-box;">
                <div class="rounded-full bg-[#FF6257]" style="width:6.2px;height:6.2px;"></div>
                <div class="rounded-full bg-[#FDBC23]" style="width:6.2px;height:6.2px;"></div>
                <div class="rounded-full bg-[#11CA3E]" style="width:6.2px;height:6.2px;"></div>
              </div>
              <!-- Domain Title Container -->
              <div class="flex flex-row justify-center items-end gap-[3.1px] flex-grow" style="width:303.88px;height:12px;box-sizing:border-box;">
                <svg width="9.3" height="9.3" viewBox="0 0 24 24" fill="none" stroke="#7D7D7D" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                <span class="font-mono font-normal text-[9.30233px] leading-[130%] text-[#7D7D7D] flex items-center" style="font-family:'Geist Mono', monospace;">Appnigma.ai</span>
              </div>
              <!-- Right spacer -->
              <div class="flex flex-row align-items-center gap-[3.1px]" style="width:48.06px;min-width:48.06px;height:6.2px;margin:0 auto;opacity:0;box-sizing:border-box;"></div>
            </div>

            <!-- Mac Window Content (height 359.69px) -->
            <div class="sf-mockup-window-content relative bg-[#262626] overflow-hidden flex items-center justify-center">
              <!-- Grid Lines Background -->
              <div class="absolute inset-0 grid grid-cols-3 pointer-events-none">
                <div class="border-r border-dashed border-[#3d3d3d]"></div>
                <div class="border-r border-dashed border-[#3d3d3d]"></div>
                <div></div>
              </div>

              <!-- Horizontal Dashed Divider Box -->
              <div class="absolute w-full h-[134.93px] border-t border-b border-dashed border-[#3D3D3D] flex items-center justify-center bg-[#3D3D3D]" style="box-sizing:border-box; border-width: 0.775194px 0px; border-style: dashed; border-color: #3D3D3D;">
                <!-- Active Card -->
                <div class="w-full h-[133.38px] bg-[#262626] flex flex-col items-center justify-center gap-[18.6px] py-[37.2093px] px-[54.2636px]" style="box-sizing:border-box;">
                  <div class="w-[24.81px] h-[24.81px] bg-white border border-[rgba(0,0,0,0.08)] rounded-[6.20155px] flex items-center justify-center shadow-sm" style="box-sizing:border-box;">
                    <svg width="12.4" height="12.4" viewBox="0 0 24 24" fill="none" stroke="#4D4D4D" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                  </div>
                  <span class="font-body font-medium text-[12.4031px] text-white text-center tracking-[-0.02px]" style="font-family:'Montserrat', sans-serif;">Prompt Screenshot</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Mac Mockup Window 2: CRM Screenshot -->
          <div class="sf-mockup-window relative w-[400px] max-w-full bg-[#262626] rounded-[9.30233px] overflow-hidden shadow-2xl flex flex-col flex-shrink-0 transition-opacity duration-300">
            <!-- Mac Window Header -->
            <div class="flex flex-row justify-between items-center bg-[#1a1a1a] flex-shrink-0" style="width:400px;height:27.91px;padding:9.30233px 0px;z-index:1;box-sizing:border-box;">
              <!-- Traffic lights container -->
              <div class="flex flex-row align-items-center gap-[3.1px]" style="width:48.06px;min-width:48.06px;height:6.2px;margin:0 auto;padding-left:9.30233px;box-sizing:border-box;">
                <div class="rounded-full bg-[#FF6257]" style="width:6.2px;height:6.2px;"></div>
                <div class="rounded-full bg-[#FDBC23]" style="width:6.2px;height:6.2px;"></div>
                <div class="rounded-full bg-[#11CA3E]" style="width:6.2px;height:6.2px;"></div>
              </div>
              <!-- Domain Title Container -->
              <div class="flex flex-row justify-center items-end gap-[3.1px] flex-grow" style="width:303.88px;height:12px;box-sizing:border-box;">
                <svg width="9.3" height="9.3" viewBox="0 0 24 24" fill="none" stroke="#7D7D7D" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                <span class="font-mono font-normal text-[9.30233px] leading-[130%] text-[#7D7D7D] flex items-center" style="font-family:'Geist Mono', monospace;">Appnigma.ai</span>
              </div>
              <!-- Right spacer -->
              <div class="flex flex-row align-items-center gap-[3.1px]" style="width:48.06px;min-width:48.06px;height:6.2px;margin:0 auto;opacity:0;box-sizing:border-box;"></div>
            </div>

            <!-- Mac Window Content (height 359.69px) -->
            <div class="sf-mockup-window-content relative bg-[#262626] overflow-hidden flex items-center justify-center">
              <!-- Grid Lines Background -->
              <div class="absolute inset-0 grid grid-cols-3 pointer-events-none">
                <div class="border-r border-dashed border-[#3d3d3d]"></div>
                <div class="border-r border-dashed border-[#3d3d3d]"></div>
                <div></div>
              </div>

              <!-- Horizontal Dashed Divider Box -->
              <div class="absolute w-full h-[134.93px] border-t border-b border-dashed border-[#3D3D3D] flex items-center justify-center bg-[#3D3D3D]" style="box-sizing:border-box; border-width: 0.775194px 0px; border-style: dashed; border-color: #3D3D3D;">
                <!-- Active Card -->
                <div class="w-full h-[133.38px] bg-[#262626] flex flex-col items-center justify-center gap-[18.6px] py-[37.2093px] px-[54.2636px]" style="box-sizing:border-box;">
                  <div class="w-[24.81px] h-[24.81px] bg-white border border-[rgba(0,0,0,0.08)] rounded-[6.20155px] flex items-center justify-center shadow-sm" style="box-sizing:border-box;">
                    <svg width="12.4" height="12.4" viewBox="0 0 24 24" fill="none" stroke="#4D4D4D" stroke-width="2"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/><path d="M3 12c0 1.66 4 3 9 3s9-1.34 9-3"/></svg>
                  </div>
                  <span class="font-body font-medium text-[12.4031px] text-white text-center tracking-[-0.02px]" style="font-family:'Montserrat', sans-serif;">CRM Screenshot</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Mac Mockup Window 3: AppExchange Screenshot -->
          <div class="sf-mockup-window relative w-[400px] max-w-full bg-[#262626] rounded-[9.30233px] overflow-hidden shadow-2xl flex flex-col flex-shrink-0 transition-opacity duration-300">
            <!-- Mac Window Header -->
            <div class="flex flex-row justify-between items-center bg-[#1a1a1a] flex-shrink-0" style="width:400px;height:27.91px;padding:9.30233px 0px;z-index:1;box-sizing:border-box;">
              <!-- Traffic lights container -->
              <div class="flex flex-row align-items-center gap-[3.1px]" style="width:48.06px;min-width:48.06px;height:6.2px;margin:0 auto;padding-left:9.30233px;box-sizing:border-box;">
                <div class="rounded-full bg-[#FF6257]" style="width:6.2px;height:6.2px;"></div>
                <div class="rounded-full bg-[#FDBC23]" style="width:6.2px;height:6.2px;"></div>
                <div class="rounded-full bg-[#11CA3E]" style="width:6.2px;height:6.2px;"></div>
              </div>
              <!-- Domain Title Container -->
              <div class="flex flex-row justify-center items-end gap-[3.1px] flex-grow" style="width:303.88px;height:12px;box-sizing:border-box;">
                <svg width="9.3" height="9.3" viewBox="0 0 24 24" fill="none" stroke="#7D7D7D" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                <span class="font-mono font-normal text-[9.30233px] leading-[130%] text-[#7D7D7D] flex items-center" style="font-family:'Geist Mono', monospace;">Appnigma.ai</span>
              </div>
              <!-- Right spacer -->
              <div class="flex flex-row align-items-center gap-[3.1px]" style="width:48.06px;min-width:48.06px;height:6.2px;margin:0 auto;opacity:0;box-sizing:border-box;"></div>
            </div>

            <!-- Mac Window Content (height 359.69px) -->
            <div class="sf-mockup-window-content relative bg-[#262626] overflow-hidden flex items-center justify-center">
              <!-- Grid Lines Background -->
              <div class="absolute inset-0 grid grid-cols-3 pointer-events-none">
                <div class="border-r border-dashed border-[#3d3d3d]"></div>
                <div class="border-r border-dashed border-[#3d3d3d]"></div>
                <div></div>
              </div>

              <!-- Horizontal Dashed Divider Box -->
              <div class="absolute w-full h-[134.93px] border-t border-b border-dashed border-[#3D3D3D] flex items-center justify-center bg-[#3D3D3D]" style="box-sizing:border-box; border-width: 0.775194px 0px; border-style: dashed; border-color: #3D3D3D;">
                <!-- Active Card -->
                <div class="w-full h-[133.38px] bg-[#262626] flex flex-col items-center justify-center gap-[18.6px] py-[37.2093px] px-[54.2636px]" style="box-sizing:border-box;">
                  <div class="w-[24.81px] h-[24.81px] bg-white border border-[rgba(0,0,0,0.08)] rounded-[6.20155px] flex items-center justify-center shadow-sm" style="box-sizing:border-box;">
                    <svg width="12.4" height="12.4" viewBox="0 0 24 24" fill="none" stroke="#4D4D4D" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                  </div>
                  <span class="font-body font-medium text-[12.4031px] text-white text-center tracking-[-0.02px]" style="font-family:'Montserrat', sans-serif;">AppExchange Screenshot</span>
                </div>
              </div>
            </div>
          </div>
    </div>
  </section>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const featureButtons = document.querySelectorAll('.sf-feature-btn');
      const track = document.querySelector('.sf-why-mock-track');
      const mockupWindows = document.querySelectorAll('.sf-mockup-window');
      const viewport = document.querySelector('.sf-why-right-viewport');

      function updateActiveIndex(index) {
        const isMobile = window.innerWidth <= 768;

        // 1. Update active button background and border
        featureButtons.forEach((b, idx) => {
          const iconBox = b.querySelector('.sf-feature-icon-box');
          const icon = b.querySelector('.sf-feature-icon');
          const desc = b.querySelector('.sf-feature-desc');
          const textWrap = b.querySelector('.sf-feature-text-wrap');

          if (idx === index) {
            b.style.height = isMobile ? 'auto' : '118px';
            b.style.backgroundColor = '#262626';

            if (icon) {
              icon.classList.remove('text-[rgba(255,255,255,0.2)]');
              icon.classList.add('text-white');
            }

            if (textWrap) {
              textWrap.style.height = isMobile ? 'auto' : '70px';
            }

            if (desc) {
              desc.style.maxHeight = isMobile ? '120px' : '42px';
              desc.style.opacity = '1';
            }
          } else {
            b.style.height = '80px';
            b.style.backgroundColor = '#151515';

            if (icon) {
              icon.classList.remove('text-white');
              icon.classList.add('text-[rgba(255,255,255,0.2)]');
            }

            if (textWrap) {
              textWrap.style.height = isMobile ? 'auto' : '18px';
            }

            if (desc) {
              desc.style.maxHeight = '0px';
              desc.style.opacity = '0';
            }
          }
        });

        // 2. Scroll/Translate mockup track
        const activeWindow = mockupWindows[index];
        if (activeWindow && viewport && track) {
          const viewportHeight = viewport.clientHeight;
          const windowHeight = activeWindow.clientHeight;
          const windowOffsetTop = activeWindow.offsetTop;
          const translateVal = (viewportHeight - windowHeight) / 2 - windowOffsetTop;
          track.style.transform = `translateY(${translateVal}px)`;
        }

        // 3. Update window opacities
        mockupWindows.forEach((win, idx) => {
          if (idx === index) {
            win.classList.remove('opacity-40');
            win.classList.add('opacity-100');
          } else {
            win.classList.remove('opacity-100');
            win.classList.add('opacity-40');
          }
        });
      }

      // Add click listeners
      featureButtons.forEach((btn, index) => {
        btn.addEventListener('click', () => updateActiveIndex(index));
      });

      // Initial alignment
      setTimeout(() => updateActiveIndex(0), 100);
      
      // Re-align on window resize to keep it perfectly centered
      window.addEventListener('resize', () => {
        const activeBtn = document.querySelector('.sf-feature-btn');
        let activeIndex = 0;
        featureButtons.forEach((b, idx) => {
          if (b.style.backgroundColor === 'rgb(38, 38, 38)' || b.style.backgroundColor === '#262626') {
            activeIndex = idx;
          }
        });
        updateActiveIndex(activeIndex);
      });
    });
  </script>

