---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<Layout title="Salesforce Native Managed Packages — Appnigma AI">
  <Header />

  <!-- Hero -->
  <section class="relative bg-white overflow-hidden" style="min-height:836px;">
    <div class="absolute inset-0 pointer-events-none">
      <img src="/assets/9c92c14de9348a125c01b7a1e53923e2f9efeaab.png" alt="" class="absolute inset-0 w-full h-full object-cover object-bottom" fetchpriority="high" />
      <div class="absolute inset-0" style="background:linear-gradient(180deg,rgba(255,255,255,1) 14%,rgba(255,255,255,0) 24.28%),linear-gradient(rgba(255,255,255,0) 51.92%,rgba(255,255,255,1) 94.71%)"></div>
    </div>
    <div class="absolute left-0 top-0 h-full pointer-events-none" style="width:893px;background:linear-gradient(to right,white 65.38%,transparent 100%);"></div>
    <div class="relative max-w-[1440px] mx-auto flex items-center" style="padding-left:120px;padding-right:120px;min-height:836px;padding-top:143px;padding-bottom:80px;">
      <div class="flex flex-col gap-16" style="width:591px;">
        <div class="flex flex-col gap-6">
          <h1 class="font-heading font-medium text-[#0a0a0a] leading-[1.1]" style="font-size:64px;letter-spacing:-1.2px;">
            Launch Native Salesforce Managed Packages in Days,
          </h1>
          <p class="font-body font-normal text-[16px] text-[#525252] leading-[1.5]" style="max-width:591px;">
            AI generates the package. You ship to AppExchange — no AppExchange consultant required.
          </p>
          <div class="flex items-center gap-2">
            <button class="btn-primary font-body font-medium text-[14px] text-white px-3 h-9 rounded-[8px] whitespace-nowrap" style="letter-spacing:-0.14px;">Book a demo</button>
            <button class="btn-secondary font-body font-medium text-[14px] text-[#1d2b31] px-3 h-9 rounded-[8px] whitespace-nowrap" style="letter-spacing:-0.14px;">Learn More</button>
          </div>
        </div>
        <div class="flex flex-col gap-2">
          <div class="flex flex-col overflow-hidden py-4">
            <div class="flex items-center gap-6">
              <div class="flex items-center">
                <div class="w-12 h-12 rounded-full border-[0.96px] border-white overflow-hidden -mr-4 relative z-10" style="background:linear-gradient(to bottom,#d1d1d1,#f9f9f9);">
                  <img src="/assets/39921c6e1a55ece00506afb87e09ce5a1f14650b.png" alt="" class="w-full h-full object-cover" />
                </div>
                <div class="w-12 h-12 rounded-full border-[0.96px] border-white overflow-hidden relative" style="background:linear-gradient(to bottom,#d1d1d1,#f9f9f9);">
                  <img src="/assets/ef10b07ee57f3b66d85380bf095ffc6d8e2ac0a0.png" alt="" class="w-full h-full object-cover" />
                </div>
              </div>
              <div class="flex flex-col">
                <span class="font-body font-semibold text-[16px] text-[#525252] leading-[1.1]">Built by ex-Salesforce AppExchange engineers</span>
                <span class="font-body font-normal text-[16px] text-[#525252] leading-[1.5]">300+ SaaS integrations shipped</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Social Proof Logo Band -->
  <section class="bg-white border-y border-[#e5e5e5]" style="padding-left:120px;padding-right:120px;">
    <div class="border-l border-r border-[#e5e5e5] py-10 flex flex-col items-center gap-10">
      <p class="font-heading font-medium text-[24px] text-[#0a0a0a] text-center" style="letter-spacing:-0.04px;">
        Teams ship 3x faster to the AppExchange with Appnigma AI
      </p>
      <div class="flex items-center justify-between w-full border border-[#e5e5e5]">
        <div class="flex flex-1 items-center justify-center py-10 border-r border-dashed border-[#e5e5e5]">
          <img src="/assets/c52285970f7f1ca9daeeb6f2c2f4c87c51529303.svg" alt="Logo" class="h-8 opacity-60 grayscale" />
        </div>
        <div class="flex flex-1 items-center justify-center py-10 border-r border-dashed border-[#e5e5e5]">
          <img src="/assets/f1273fac836c9e2da49c548d7fd9f3a527091ccd.svg" alt="Logo" class="h-8 opacity-60 grayscale" />
        </div>
        <div class="flex flex-1 items-center justify-center py-10 border-r border-dashed border-[#e5e5e5]">
          <img src="/assets/563b12dafdefe80c2bee0277124c24206230a6d9.svg" alt="Logo" class="h-8 opacity-60 grayscale" />
        </div>
        <div class="flex flex-1 items-center justify-center py-10 border-r border-dashed border-[#e5e5e5]">
          <img src="/assets/5041776b6f80ee7654b666512c90c5c8e114c935.svg" alt="Logo" class="h-8 opacity-60 grayscale" />
        </div>
        <div class="flex flex-1 items-center justify-center py-10">
          <img src="/assets/1d3f028314f5e7aead2d462d5b1eca9f51a542c8.svg" alt="Logo" class="h-8 opacity-60 grayscale" />
        </div>
      </div>
    </div>
  </section>

  <!-- Why Appnigma for Salesforce (dark) -->
  <section class="bg-[#151515]" style="padding-left:120px;padding-right:120px;">
    <div class="border-l border-r border-[#3d3d3d] py-20 flex flex-row items-start gap-0" style="min-height:740px;">
      <!-- Left: text + features -->
      <div class="flex flex-col border-t border-b border-[#3d3d3d]" style="width:600px;min-height:580px;">
        <!-- Heading block -->
        <div class="flex flex-col gap-4 p-6" style="flex:1;">
          <div class="inline-flex items-center px-3 py-2 border border-[rgba(255,255,255,0.05)] bg-[rgba(255,255,255,0.05)]">
            <span class="font-body font-normal text-[12px] text-[rgba(255,255,255,0.5)] leading-[1.5]">Why Appnigma for Salesforce</span>
          </div>
          <h2 class="font-heading font-medium text-white leading-[1.1]" style="font-size:32px;letter-spacing:-1.2px;">Native by default.<br />Generated by design.</h2>
          <p class="font-body font-normal text-[16px] text-[rgba(255,255,255,0.5)] leading-[1.5]">
            The same artifacts a senior Salesforce engineer would write by hand — Apex, LWC, metadata, test classes — only faster, cheaper, and reproducible.
          </p>
        </div>
        <!-- Feature: Days, not months -->
        <div class="flex items-start gap-4 p-6 border-t border-[#3d3d3d] bg-[#262626]" style="min-height:118px;">
          <div class="flex-shrink-0 w-8 h-8 border border-[rgba(255,255,255,0.1)] bg-[rgba(255,255,255,0.05)] flex items-center justify-center">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="white"><path d="M9 1L3 9h5l-1 6 6-8H8l1-6z"/></svg>
          </div>
          <div class="flex flex-col gap-2">
            <span class="font-body font-semibold text-[16px] text-white leading-[1.1]">Days, not months</span>
            <p class="font-body font-normal text-[14px] text-[rgba(255,255,255,0.5)] leading-[1.5]">Describe the package — objects, flows, Lightning components — and get a same-managed package, fraction of the time.</p>
          </div>
        </div>
        <!-- Feature: You own the package -->
        <div class="flex items-center gap-4 p-6 border-t border-[#3d3d3d]">
          <div class="flex-shrink-0 w-8 h-8 border border-[rgba(255,255,255,0.1)] bg-[rgba(255,255,255,0.05)] flex items-center justify-center">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="rgba(255,255,255,0.2)"><path d="M2 4l6-3 6 3v4c0 3-6 6-6 6S2 11 2 8V4z"/></svg>
          </div>
          <span class="font-body font-semibold text-[16px] text-white leading-[1.1]">You own the package</span>
        </div>
        <!-- Feature: Security Review, embedded -->
        <div class="flex items-center gap-4 p-6 border-t border-[#3d3d3d]">
          <div class="flex-shrink-0 w-8 h-8 border border-[rgba(255,255,255,0.1)] bg-[rgba(255,255,255,0.05)] flex items-center justify-center">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="rgba(255,255,255,0.2)"><rect x="3" y="7" width="10" height="7" rx="1"/><path d="M5 7V5a3 3 0 0 1 6 0v2"/></svg>
          </div>
          <span class="font-body font-semibold text-[16px] text-white leading-[1.1]">Security Review, embedded</span>
        </div>
      </div>

      <!-- Right: mock UI cards -->
      <div class="relative flex-shrink-0" style="width:600px;height:580px;">
        <div class="absolute inset-0 bg-[#1b1b1b] border border-[#333]"></div>
        <div class="absolute flex flex-col gap-12" style="width:400px;left:100px;top:90px;">
          <!-- Mock window 1: Prompt Screenshot -->
          <div class="bg-[#262626] rounded-[9px] overflow-hidden shadow-lg">
            <div class="flex items-center justify-between px-3 py-2 border-b border-[#3d3d3d]">
              <div class="flex items-center gap-1.5">
                <div class="w-1.5 h-1.5 rounded-full bg-[#FF6257]"></div>
                <div class="w-1.5 h-1.5 rounded-full bg-[#FDBC23]"></div>
                <div class="w-1.5 h-1.5 rounded-full bg-[#11CA3E]"></div>
              </div>
              <span class="font-mono text-[9px] text-[#7d7d7d]">Appnigma.ai</span>
              <div class="w-6"></div>
            </div>
            <div class="bg-[#262626] flex flex-col items-center justify-center gap-3 py-8 border-t border-dashed border-[#3d3d3d]">
              <div class="w-6 h-6 bg-white rounded-[6px] flex items-center justify-center">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="#4d4d4d"><path d="M1 2h10v8H1z" rx="1"/><path d="M3 5h6M3 7h4"/></svg>
              </div>
              <span class="font-body font-medium text-[12px] text-white text-center">Prompt Screenshot</span>
            </div>
          </div>
          <!-- Mock window 2: CRM Screenshot -->
          <div class="bg-[#262626] rounded-[9px] overflow-hidden shadow-lg">
            <div class="flex items-center justify-between px-3 py-2 border-b border-[#3d3d3d]">
              <div class="flex items-center gap-1.5">
                <div class="w-1.5 h-1.5 rounded-full bg-[#FF6257]"></div>
                <div class="w-1.5 h-1.5 rounded-full bg-[#FDBC23]"></div>
                <div class="w-1.5 h-1.5 rounded-full bg-[#11CA3E]"></div>
              </div>
              <span class="font-mono text-[9px] text-[#7d7d7d]">Appnigma.ai</span>
              <div class="w-6"></div>
            </div>
            <div class="bg-[#262626] flex flex-col items-center justify-center gap-3 py-8 border-t border-dashed border-[#3d3d3d]">
              <div class="w-6 h-6 bg-white rounded-[6px] flex items-center justify-center">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="#4d4d4d"><circle cx="6" cy="5" r="3"/><path d="M1 11a5 5 0 0 1 10 0"/></svg>
              </div>
              <span class="font-body font-medium text-[12px] text-white text-center">CRM Screenshot</span>
            </div>
          </div>
          <!-- Mock window 3: AppExchange Screenshot -->
          <div class="bg-[#262626] rounded-[9px] overflow-hidden shadow-lg">
            <div class="flex items-center justify-between px-3 py-2 border-b border-[#3d3d3d]">
              <div class="flex items-center gap-1.5">
                <div class="w-1.5 h-1.5 rounded-full bg-[#FF6257]"></div>
                <div class="w-1.5 h-1.5 rounded-full bg-[#FDBC23]"></div>
                <div class="w-1.5 h-1.5 rounded-full bg-[#11CA3E]"></div>
              </div>
              <span class="font-mono text-[9px] text-[#7d7d7d]">Appnigma.ai</span>
              <div class="w-6"></div>
            </div>
            <div class="bg-[#262626] flex flex-col items-center justify-center gap-3 py-8 border-t border-dashed border-[#3d3d3d]">
              <div class="w-6 h-6 bg-white rounded-[6px] flex items-center justify-center">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="#4d4d4d"><path d="M6 1l1.5 3h3.5l-3 2 1.5 3.5L6 8l-3.5 1.5 1.5-3.5-3-2h3.5z"/></svg>
              </div>
              <span class="font-body font-medium text-[12px] text-white text-center">AppExchange Screenshot</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Compare -->
  <section class="bg-white border-b border-[#e5e5e5]" style="padding-left:120px;padding-right:120px;">
    <div class="border-l border-r border-[#e5e5e5] py-20 flex flex-col gap-20">
      <div class="px-6 flex flex-col gap-4">
        <div class="border border-[#e5e5e5] bg-white px-3 py-2 inline-flex self-start">
          <span class="font-body font-normal text-[12px] text-[#525252] leading-[1.5]">Compare</span>
        </div>
        <div class="flex flex-col gap-2">
          <h2 class="font-heading font-medium text-[#0a0a0a] leading-[1.1]" style="font-size:32px;letter-spacing:-1.2px;">Compared to the alternatives.</h2>
          <p class="font-body font-normal text-[16px] text-[#525252] leading-[1.5]">Faster than consultants. Cleaner than middleware. Less painful than DIY.</p>
        </div>
      </div>

      <!-- Cards -->
      <div class="flex gap-6 overflow-x-auto px-6">
        <div class="flex-shrink-0 relative" style="width:298px;height:359px;">
          <div class="absolute inset-0 bg-white border border-[#e5e5e5]"></div>
          <div class="absolute bg-[#0a0a0a] text-white px-3 py-2 flex items-center gap-2" style="top:16px;left:16px;">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="white"><path d="M8 8a4 4 0 1 0 0-8 4 4 0 0 0 0 8zm-6 8a6 6 0 1 1 12 0H2z"/></svg>
            <span class="font-body font-normal text-[12px]">Yours</span>
          </div>
          <div class="absolute border border-[#0a0a0a] flex flex-col p-4 gap-10" style="top:16px;left:16px;right:16px;bottom:16px;padding-top:64px;">
            <p class="font-heading font-medium text-[18px] text-[#0a0a0a] leading-[1.2]" style="letter-spacing:-1.2px;">Your code. Your IP. No vendor lock-in, no rent forever.</p>
            <div class="bg-white rounded-[9px] border border-[#e5e5e5] overflow-hidden shadow-sm">
              <div class="flex items-center gap-1.5 px-2 py-1.5 border-b border-[#e5e5e5]">
                <div class="w-1.5 h-1.5 rounded-full bg-[#ee6d5e]"></div>
                <div class="w-1.5 h-1.5 rounded-full bg-[#f3bf4a]"></div>
                <div class="w-1.5 h-1.5 rounded-full bg-[#5dc753]"></div>
                <span class="font-mono text-[8px] text-[#7d7d7d] ml-auto">Appnigma.ai</span>
              </div>
              <div class="h-16 bg-[#fafafa]"></div>
            </div>
          </div>
        </div>
        <div class="flex-shrink-0 relative" style="width:298px;height:359px;">
          <div class="absolute inset-0 bg-white border border-[#e5e5e5]"></div>
          <div class="absolute bg-[#0a0a0a] text-white px-3 py-2 flex items-center gap-2" style="top:16px;left:16px;">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="white"><path d="M8 0L6 6H0l5 4-2 6 5-4 5 4-2-6 5-4h-6z"/></svg>
            <span class="font-body font-normal text-[12px]">Fast</span>
          </div>
          <div class="absolute border border-[#0a0a0a] flex flex-col p-4 gap-10" style="top:16px;left:16px;right:16px;bottom:16px;padding-top:64px;">
            <p class="font-heading font-medium text-[18px] text-[#0a0a0a] leading-[1.2]" style="letter-spacing:-1.2px;">Ship in days, not quarters. While consultants scope, we deliver.</p>
            <div class="bg-white rounded-[9px] border border-[#e5e5e5] overflow-hidden shadow-sm">
              <div class="flex items-center gap-1.5 px-2 py-1.5 border-b border-[#e5e5e5]">
                <div class="w-1.5 h-1.5 rounded-full bg-[#ee6d5e]"></div>
                <div class="w-1.5 h-1.5 rounded-full bg-[#f3bf4a]"></div>
                <div class="w-1.5 h-1.5 rounded-full bg-[#5dc753]"></div>
                <span class="font-mono text-[8px] text-[#7d7d7d] ml-auto">Appnigma.ai</span>
              </div>
              <div class="h-16 bg-[#fafafa]"></div>
            </div>
          </div>
        </div>
        <div class="flex-shrink-0 relative" style="width:298px;height:359px;">
          <div class="absolute inset-0 bg-white border border-[#e5e5e5]"></div>
          <div class="absolute bg-[#0a0a0a] text-white px-3 py-2 flex items-center gap-2" style="top:16px;left:16px;">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="white"><path d="M10 2H6a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2h4a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2z"/></svg>
            <span class="font-body font-normal text-[12px]">Native</span>
          </div>
          <div class="absolute border border-[#0a0a0a] flex flex-col p-4 gap-10" style="top:16px;left:16px;right:16px;bottom:16px;padding-top:64px;">
            <p class="font-heading font-medium text-[18px] text-[#0a0a0a] leading-[1.2]" style="letter-spacing:-1.2px;">Built as a managed package. Lives inside Salesforce the way it should.</p>
            <div class="bg-white rounded-[9px] border border-[#e5e5e5] overflow-hidden shadow-sm">
              <div class="flex items-center gap-1.5 px-2 py-1.5 border-b border-[#e5e5e5]">
                <div class="w-1.5 h-1.5 rounded-full bg-[#ee6d5e]"></div>
                <div class="w-1.5 h-1.5 rounded-full bg-[#f3bf4a]"></div>
                <div class="w-1.5 h-1.5 rounded-full bg-[#5dc753]"></div>
                <span class="font-mono text-[8px] text-[#7d7d7d] ml-auto">Appnigma.ai</span>
              </div>
              <div class="h-16 bg-[#fafafa]"></div>
            </div>
          </div>
        </div>
        <div class="flex-shrink-0 relative" style="width:298px;height:359px;">
          <div class="absolute inset-0 bg-white border border-[#e5e5e5]"></div>
          <div class="absolute bg-[#151515] text-white px-3 py-2 flex items-center gap-2" style="top:16px;left:16px;">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="white"><path d="M8 1a7 7 0 1 0 0 14A7 7 0 0 0 8 1zm0 3a1 1 0 1 1 0 2 1 1 0 0 1 0-2zm0 3h1v5H7V7h1z"/></svg>
            <span class="font-body font-normal text-[12px]">Honest</span>
          </div>
          <div class="absolute border border-[#151515] flex flex-col p-4 gap-10" style="top:16px;left:16px;right:16px;bottom:16px;padding-top:64px;">
            <p class="font-heading font-medium text-[18px] text-[#0a0a0a] leading-[1.2]" style="letter-spacing:-1.2px;">One price, scoped to your budget. No retainers, no surprise invoices.</p>
            <div class="bg-white rounded-[9px] border border-[#e5e5e5] overflow-hidden shadow-sm">
              <div class="flex items-center gap-1.5 px-2 py-1.5 border-b border-[#e5e5e5]">
                <div class="w-1.5 h-1.5 rounded-full bg-[#ee6d5e]"></div>
                <div class="w-1.5 h-1.5 rounded-full bg-[#f3bf4a]"></div>
                <div class="w-1.5 h-1.5 rounded-full bg-[#5dc753]"></div>
                <span class="font-mono text-[8px] text-[#7d7d7d] ml-auto">Appnigma.ai</span>
              </div>
              <div class="h-16 bg-[#fafafa]"></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Comparison Table -->
      <div class="border border-[#e5e5e5]">
        <!-- Header row -->
        <div class="flex border-b border-[#e5e5e5] bg-[#fafafa]">
          <div class="flex items-center px-6 py-4 font-heading font-medium text-[16px] text-[#4d4d4d]" style="width:320px;flex-shrink:0;">Capability</div>
          <div class="flex-1 flex items-center justify-center flex-col py-4 bg-[#0a0a0a] border-l border-[#0a0a0a]">
            <span class="font-heading font-medium text-[16px] text-white">Appnigma AI</span>
            <span class="font-body font-normal text-[12px] text-[rgba(255,255,255,0.7)]">Tailored to your budget</span>
          </div>
          <div class="flex-1 flex flex-col items-center justify-center py-4 border-l border-[#e5e5e5]">
            <span class="font-heading font-medium text-[16px] text-[#4d4d4d]">Consultants</span>
            <span class="font-body font-normal text-[12px] text-[#262626]">from $150K/yr</span>
          </div>
          <div class="flex-1 flex flex-col items-center justify-center py-4 border-l border-[#e5e5e5]">
            <span class="font-heading font-medium text-[16px] text-[#4d4d4d]">Middleware</span>
            <span class="font-body font-normal text-[12px] text-[#262626]">from $30K/yr</span>
          </div>
          <div class="flex-1 flex flex-col items-center justify-center py-4 border-l border-[#e5e5e5]">
            <span class="font-heading font-medium text-[16px] text-[#4d4d4d]">DIY</span>
            <span class="font-body font-normal text-[12px] text-[#262626]">from $95K/yr</span>
          </div>
        </div>
        {[
          { label: 'Native managed package', vals: ['✓','–','–','partial'] },
          { label: 'Security Review ready',   vals: ['✓','partial','–','–'] },
          { label: 'AppExchange listing',     vals: ['✓','✓','–','–'] },
          { label: 'Days, not months',        vals: ['✓','–','✓','–'] },
          { label: 'You own the IP',          vals: ['✓','–','✓','✓'] },
          { label: 'No service contract',     vals: ['✓','–','✓','✓'] },
        ].map(row => (
          <div class="flex border-b border-[#e5e5e5] last:border-b-0">
            <div class="flex items-center gap-2 px-6 py-3 font-body text-[14px] text-[#4d4d4d]" style="width:320px;flex-shrink:0;">{row.label}</div>
            {row.vals.map((v, i) => (
              <div class={`flex-1 flex items-center justify-center py-3 border-l border-[#e5e5e5] ${i === 0 ? 'bg-[#fafafa] border-l-[#0a0a0a]' : ''}`}>
                {v === '✓' ? (
                  <span class="w-5 h-5 rounded-full bg-[#0a0a0a] flex items-center justify-center">
                    <svg width="10" height="10" viewBox="0 0 12 12" fill="none"><path d="M2 6l3 3 5-5" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </span>
                ) : (
                  <span class="font-body text-[14px] text-[#262626]">{v}</span>
                )}
