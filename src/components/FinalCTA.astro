<section class="final-cta-section bg-[#151515] px-section relative overflow-hidden" style="padding-left:120px;padding-right:120px;min-height:539px;">
  <div class="final-cta-content flex flex-col" style="padding-top:138px;padding-bottom:128px;max-width:747px;">
    <div class="flex flex-col gap-4 mb-16">
      <h2 class="final-cta-h2 font-heading font-normal text-white leading-[1.1] whitespace-pre-wrap" style="font-size:56px;letter-spacing:-1.2px;">Ship your CRM package&nbsp;<br />this quarter.</h2>
      <p class="font-body font-normal text-white text-[16px] leading-[1.5]">Book a 30-minute walkthrough. We'll generate your first package live.</p>
    </div>
    <div class="flex items-center gap-4">
      <button class="btn-secondary font-body font-medium text-[14px] text-[#202b30] px-3 h-9 rounded-[8px] whitespace-nowrap" style="letter-spacing:-0.14px;">Book A Demo</button>
      <button class="border border-white font-body font-medium text-[14px] text-white px-3 h-9 rounded-[8px] whitespace-nowrap" style="letter-spacing:-0.14px;">View Pricing</button>
    </div>
  </div>
  <!-- 3D logo image -->
  <div class="final-cta-img absolute right-[120px] top-1/2 -translate-y-1/2" style="width:477px;height:477px;">
