---
---
<header class="bg-white sticky top-0 z-50 border-b border-[#e5e5e5]">
  <div class="max-w-[1440px] mx-auto px-section h-16 flex items-center justify-between" style="padding-left:120px;padding-right:120px;">
    <!-- Logo + Nav -->
    <div class="flex items-center gap-8">
      <a href="#" class="flex items-center gap-2">
        <img src="/assets/d4fa65061f8d343fe1b5f7058e5c694dca4a764b.png" alt="Appnigma AI" class="w-6 h-6 rounded-[4.5px] object-contain" />
        <span class="font-heading font-medium text-[16px] text-[#0a0a0a] tracking-tight whitespace-nowrap">Appnigma AI</span>
      </a>
      <nav class="hidden md:flex items-center gap-8">
        <a href="#" class="flex items-center gap-1 font-body font-medium text-[14px] text-[#525252] hover:text-[#0a0a0a] transition-colors whitespace-nowrap">
          Platform
          <img src="/assets/4d2e98748663381048e2d547c4aee7dd4eb9d2b0.svg" alt="" class="w-3.5 h-3.5" loading="lazy" />
        </a>
        <a href="#" class="font-body font-medium text-[14px] text-[#525252] hover:text-[#0a0a0a] transition-colors whitespace-nowrap">Pricing</a>
        <a href="#" class="font-body font-medium text-[14px] text-[#525252] hover:text-[#0a0a0a] transition-colors whitespace-nowrap">Customers</a>
        <a href="#" class="flex items-center gap-1 font-body font-medium text-[14px] text-[#525252] hover:text-[#0a0a0a] transition-colors whitespace-nowrap">
          Resources
          <img src="/assets/4d2e98748663381048e2d547c4aee7dd4eb9d2b0.svg" alt="" class="w-3.5 h-3.5" loading="lazy" />
        </a>
      </nav>
    </div>
    <!-- CTA Buttons -->
    <div class="flex items-center gap-3">
      <button class="header-cta font-body font-medium text-[14px] text-[#202b30] px-2 py-2 rounded-[8px] hover:bg-gray-50 transition-colors tracking-[var(--letter-spacing)] whitespace-nowrap" style="letter-spacing:-0.14px">Sign In</button>
      <button class="header-cta btn-primary font-body font-medium text-[14px] text-white px-3 h-8 rounded-[8px] whitespace-nowrap" style="letter-spacing:-0.14px">Book a demo</button>
      <button class="mobile-menu-btn" aria-label="Menu" style="display:none;">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#0a0a0a" stroke-width="1.8" stroke-linecap="round"><path d="M4 8h16M4 16h16"/></svg>
      </button>
    </div>
  </div>
</header>
