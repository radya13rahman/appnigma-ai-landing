---
---
<header class="bg-white sticky top-0 z-50 border-b border-[#e5e5e5]" id="site-header">
  <div class="max-w-[1440px] mx-auto h-16 flex items-center justify-between" style="padding-left:120px;padding-right:120px;">
    <!-- Logo + Nav -->
    <div class="flex items-center gap-8">
      <a href="/" class="flex items-center gap-2">
        <img src="/assets/d4fa65061f8d343fe1b5f7058e5c694dca4a764b.png" alt="Appnigma AI" class="w-6 h-6 rounded-[4.5px] object-contain" />
        <span class="font-heading font-medium text-[16px] text-[#0a0a0a] tracking-tight whitespace-nowrap">Appnigma AI</span>
      </a>
      <nav class="hidden md:flex items-center gap-8 relative">
        <!-- Platform dropdown trigger -->
        <div class="relative" id="platform-menu">
          <button
            id="platform-btn"
            class="flex items-center gap-1 font-body font-medium text-[14px] text-[#525252] hover:text-[#0a0a0a] transition-colors whitespace-nowrap"
            aria-expanded="false"
            aria-haspopup="true"
          >
            Platform
            <svg id="platform-chevron" width="14" height="14" viewBox="0 0 14 14" fill="none" class="transition-transform duration-200">
              <path d="M3.5 5.25L7 8.75L10.5 5.25" stroke="#525252" stroke-width="1.17" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>
        <a href="#" class="font-body font-medium text-[14px] text-[#525252] hover:text-[#0a0a0a] transition-colors whitespace-nowrap">Pricing</a>
        <a href="#" class="font-body font-medium text-[14px] text-[#525252] hover:text-[#0a0a0a] transition-colors whitespace-nowrap">Customers</a>
        <div class="relative">
          <button class="flex items-center gap-1 font-body font-medium text-[14px] text-[#525252] hover:text-[#0a0a0a] transition-colors whitespace-nowrap">
            Resources
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
              <path d="M3.5 5.25L7 8.75L10.5 5.25" stroke="#525252" stroke-width="1.17" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>
      </nav>
    </div>
    <!-- CTA Buttons -->
    <div class="flex items-center gap-3">
      <button class="font-body font-medium text-[14px] text-[#202b30] px-2 py-2 rounded-[8px] hover:bg-gray-50 transition-colors whitespace-nowrap" style="letter-spacing:-0.14px">Sign In</button>
      <button class="btn-primary font-body font-medium text-[14px] text-white px-3 h-8 rounded-[8px] whitespace-nowrap" style="letter-spacing:-0.14px">Book a demo</button>
      <button class="mobile-menu-btn" aria-label="Menu" style="display:none;">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#0a0a0a" stroke-width="1.8" stroke-linecap="round"><path d="M4 8h16M4 16h16"/></svg>
      </button>
    </div>
  </div>

  <!-- Platform dropdown panel -->
  <div
    id="platform-dropdown"
    class="hidden absolute left-0 right-0 bg-white border-b border-[#e5e5e5] z-40"
    style="top:64px;"
  >
    <div class="max-w-[1440px] mx-auto" style="padding-left:120px;padding-right:120px;">
      <div class="border-l border-r border-[#e5e5e5] px-6 py-6 flex flex-col gap-4">
        <!-- Salesforce -->
        <a href="/salesforce" class="flex items-center gap-4 py-3 hover:bg-[#fafafa] rounded transition-colors group">
          <div class="flex-shrink-0 w-16 h-16 bg-[#fafafa] border border-[#e5e5e5] flex items-center justify-center overflow-hidden">
            <img src="/assets/8a78f5b5a07ab3a18319e0a602ccf041fe32c461.svg" alt="Salesforce" class="w-10 h-10 object-contain" />
          </div>
          <div class="flex flex-col">
            <span class="font-body font-semibold text-[16px] text-[#525252] leading-[1.1]">Salesforces</span>
            <span class="font-body font-normal text-[16px] text-[#525252] leading-[1.5]">Native managed packages</span>
          </div>
        </a>
        <!-- HubSpot -->
        <a href="#" class="flex items-center gap-4 py-3 hover:bg-[#fafafa] rounded transition-colors group">
          <div class="flex-shrink-0 w-16 h-16 bg-[#fafafa] border border-[#e5e5e5] flex items-center justify-center overflow-hidden">
            <img src="/assets/hubspot-icon.png" alt="HubSpot" class="w-10 h-10 object-contain" />
          </div>
          <div class="flex flex-col">
            <span class="font-body font-semibold text-[16px] text-[#525252] leading-[1.1]">HubSpot</span>
            <span class="font-body font-normal text-[16px] text-[#525252] leading-[1.5]">Marketplace-ready apps</span>
          </div>
        </a>
        <!-- Don't see your CRM? -->
        <a href="#" class="flex items-center gap-4 py-3 hover:bg-[#fafafa] rounded transition-colors group">
          <div class="flex-shrink-0 w-16 h-16 bg-[#fafafa] border border-[#e5e5e5] flex items-center justify-center">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#0a0a0a" stroke-width="1.5">
              <rect x="3" y="4" width="18" height="16" rx="2"/>
              <path d="M8 2v4M16 2v4M3 10h18"/>
              <path d="M9 16l1.5 1.5L15 13" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div class="flex flex-col">
            <span class="font-body font-semibold text-[16px] text-[#525252] leading-[1.1]">Don't see your CRM?</span>
            <span class="font-body font-normal text-[16px] text-[#525252] leading-[1.5]">Contact Us</span>
          </div>
        </a>
      </div>
    </div>
  </div>
</header>

<style>
  .btn-primary {
    background: linear-gradient(180deg, rgba(255,255,255,0.12) 0%, rgba(255,255,255,0) 100%), #0085FF;
    box-shadow: 0px 1px 2px rgba(28,63,173,0.48), 0px 0px 0px 1px #0085FF;
  }
</style>

<script>
  const btn = document.getElementById('platform-btn');
  const dropdown = document.getElementById('platform-dropdown');
  const chevron = document.getElementById('platform-chevron');

  function openDropdown() {
    dropdown?.classList.remove('hidden');
    btn?.setAttribute('aria-expanded', 'true');
    chevron?.style.setProperty('transform', 'rotate(180deg)');
  }
  function closeDropdown() {
    dropdown?.classList.add('hidden');
    btn?.setAttribute('aria-expanded', 'false');
    chevron?.style.setProperty('transform', 'rotate(0deg)');
  }

  btn?.addEventListener('click', (e) => {
    e.stopPropagation();
    const isOpen = dropdown && !dropdown.classList.contains('hidden');
    isOpen ? closeDropdown() : openDropdown();
  });

  document.addEventListener('click', (e) => {
    const menu = document.getElementById('platform-menu');
    if (menu && !menu.contains(e.target as Node) && dropdown && !dropdown.contains(e.target as Node)) {
      closeDropdown();
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeDropdown();
  });
</script>
