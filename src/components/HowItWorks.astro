---
---
<section class="bg-white px-section" style="padding-left:120px;padding-right:120px;">
  <div class="how-it-works-row border-l border-r border-[#e5e5e5] flex items-stretch overflow-hidden py-20">
    <!-- Left text column -->
    <div class="how-it-works-col flex flex-col border-t border-b border-[#e5e5e5] flex-shrink-0" style="width:600px;">
      <!-- Header info -->
      <div class="flex flex-col gap-4 p-6">
        <div class="border border-[#e5e5e5] bg-white px-3 py-2 inline-flex self-start">
          <span class="font-body font-normal text-[12px] text-[#525252] leading-[1.5]">How it works</span>
        </div>
        <h2 class="font-heading font-medium text-[32px] text-[#0a0a0a] leading-[1.1]" style="letter-spacing:-1.2px;">
          You describe it. You ship it.<br />We handle everything in between.
        </h2>
        <p class="font-body font-normal text-[16px] text-[#525252] leading-[1.5]">
          Skip the six-month consulting engagement. Ship your package in days.
        </p>
      </div>
      <!-- Step 1 - active -->
      <div class="bg-[#f9f9f9] border-t border-b border-[#e5e5e5] p-6 flex flex-col gap-2.5">
        <p class="font-body font-semibold text-[16px] text-[#0a0a0a] leading-[1.1]">#1 Describe your app</p>
        <p class="font-body font-normal text-[14px] text-[#525252] leading-[1.5]">Tell Appnigma what you're building in plain English. Objects, flows, Lightning components, Apex — no spec doc, no schemas, no Salesforce architect required.</p>
      </div>
      <!-- Step 2 -->
      <button class="bg-white border-b border-[#e5e5e5] p-6 text-left hover:bg-[#f9f9f9] transition-colors">
        <p class="font-body font-semibold text-[16px] text-[#0a0a0a] leading-[1.1]">#2 Review inside your CRM</p>
      </button>
      <!-- Step 3 -->
      <button class="bg-white p-6 text-left hover:bg-[#f9f9f9] transition-colors">
        <p class="font-body font-semibold text-[16px] text-[#0a0a0a] leading-[1.1]">#3 Push to AppExchange</p>
      </button>
    </div>
    <!-- Right visual -->
    <div class="how-it-works-visual bg-[#fafafa] border border-[#e5e5e5] overflow-hidden flex-shrink-0 flex items-center justify-center" style="width:600px;">
      <div>
        <!-- Browser mockup -->
        <div class="how-it-works-browser bg-white rounded-[9px] overflow-hidden shadow-[0px_0px_0px_0.775px_rgba(0,0,0,0.08),0px_1.55px_1.55px_rgba(0,0,0,0.04),0px_6.2px_12.4px_-3.1px_rgba(0,0,0,0.04)]" style="width:400px;height:388px;">
          <!-- Browser chrome -->
          <div class="flex items-center justify-between h-7 relative" style="box-shadow:0 0 0 0.775px rgba(0,0,0,0.08);">
            <div class="flex items-center gap-1 pl-2.5 pr-3.5">
              <div class="w-1.5 h-1.5 rounded-full bg-[#ee6d5e]"></div>
              <div class="w-1.5 h-1.5 rounded-full bg-[#f3bf4a]"></div>
              <div class="w-1.5 h-1.5 rounded-full bg-[#5dc753]"></div>
            </div>
            <div class="flex items-center gap-1 flex-1 justify-center">
              <img src="/assets/f1273fac836c9e2da49c548d7fd9f3a527091ccd.svg" alt="" class="w-2.5 h-2.5" loading="lazy" />
              <span style="font-family:'Courier New',monospace;font-size:9px;color:#7d7d7d;">Appnigma.ai</span>
            </div>
            <div class="flex items-center gap-1 pl-2.5 pr-3.5 opacity-0">
              <div class="w-1.5 h-1.5 rounded-full bg-[#ee6d5e]"></div>
              <div class="w-1.5 h-1.5 rounded-full bg-[#f3bf4a]"></div>
              <div class="w-1.5 h-1.5 rounded-full bg-[#5dc753]"></div>
            </div>
          </div>
          <!-- Browser content -->
          <div class="flex flex-col" style="height:calc(100% - 28px);">
            <!-- Top grid row -->
            <div class="grid grid-cols-3 border-b border-[rgba(0,0,0,0.06)]" style="flex:1;">
              <div class="bg-white border-r border-[rgba(0,0,0,0.06)]"></div>
              <div class="bg-white border-r border-[rgba(0,0,0,0.06)]"></div>
              <div class="bg-white"></div>
            </div>
            <!-- Center prompt area -->
            <div class="flex items-center justify-center gap-3 border-b border-[rgba(0,0,0,0.06)]" style="padding:16px 0;">
              <div class="bg-white border border-[rgba(0,0,0,0.08)] rounded-[6px] flex items-center justify-center p-2" style="width:25px;height:25px;flex-shrink:0;">
                <img src="/assets/8bdadbe32de933dd6e3e52ea04395c3449c2888b.svg" alt="" class="w-3 h-3" loading="lazy" />
              </div>
              <span style="font-family:'Geist',sans-serif;font-size:12.4px;color:#151515;font-weight:500;letter-spacing:-0.25px;">Prompt Screenshot</span>
            </div>
            <!-- Bottom grid row -->
            <div class="grid grid-cols-3" style="flex:1;">
              <div class="bg-white border-r border-[rgba(0,0,0,0.06)]"></div>
              <div class="bg-white border-r border-[rgba(0,0,0,0.06)]"></div>
              <div class="bg-white"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
