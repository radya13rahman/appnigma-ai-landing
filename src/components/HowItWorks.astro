<section class="hiw-section bg-white relative max-w-[1440px] mx-auto" style="padding-left:120px;padding-right:120px;height:740px;box-sizing:border-box;">
  <div class="hiw-row border-l border-r border-[#e5e5e5] flex flex-row items-start gap-0" style="height:740px;padding:80px 0;box-sizing:border-box;background:#fff;">

    <!-- Left: heading + steps -->
    <div class="hiw-left flex flex-col border-t border-b border-[#e5e5e5] flex-shrink-0" style="width:600px;height:580px;box-sizing:border-box;">

      <!-- Heading block (302px) -->
      <div class="flex flex-col gap-[16px] p-[24px] flex-shrink-0" style="width:600px;height:302px;box-sizing:border-box;">
