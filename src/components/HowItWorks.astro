<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const stepButtons = document.querySelectorAll('.hiw-step-btn');
    const track = document.querySelector('.hiw-mock-track');
    const mockupWindows = document.querySelectorAll('.hiw-mock-window');
    const viewport = document.querySelector('.hiw-right-viewport');

    function updateActiveIndex(index) {
      const isMobile = window.innerWidth <= 768;

      stepButtons.forEach((b, idx) => {
        const iconBox = b.querySelector('.hiw-step-icon-box');
        const icon = b.querySelector('.hiw-step-icon');
        const desc = b.querySelector('.hiw-step-desc');
        const textWrap = b.querySelector('.hiw-step-text-wrap');

        if (idx === index) {
          b.style.height = isMobile ? 'auto' : '118px';
          b.style.backgroundColor = '#f9f9f9';

          if (icon) icon.style.color = '#0a0a0a';
          if (iconBox) iconBox.style.backgroundColor = '#ffffff';

          if (textWrap) textWrap.style.height = isMobile ? 'auto' : '70px';

          if (desc) {
            desc.style.maxHeight = isMobile ? '120px' : '42px';
            desc.style.opacity = '1';
          }
        } else {
          b.style.height = '80px';
          b.style.backgroundColor = '#ffffff';

          if (icon) icon.style.color = 'rgba(0,0,0,0.2)';
          if (iconBox) iconBox.style.backgroundColor = '#fafafa';

          if (textWrap) textWrap.style.height = isMobile ? 'auto' : '18px';

          if (desc) {
            desc.style.maxHeight = '0px';
            desc.style.opacity = '0';
          }
        }
      });

      // Translate track to center the active window
      const activeWindow = mockupWindows[index];
      if (activeWindow && viewport && track) {
        const viewportHeight = viewport.clientHeight;
        const windowHeight = activeWindow.clientHeight;
        const windowOffsetTop = activeWindow.offsetTop;
        const translateVal = (viewportHeight - windowHeight) / 2 - windowOffsetTop;
        track.style.transform = `translateY(${translateVal}px)`;
      }

      // Update window opacities
      mockupWindows.forEach((win, idx) => {
        if (idx === index) {
          win.classList.remove('opacity-40');
          win.classList.add('opacity-100');
        } else {
          win.classList.remove('opacity-100');
          win.classList.add('opacity-40');
        }
      });
    }

    stepButtons.forEach((btn, index) => {
      btn.addEventListener('click', () => updateActiveIndex(index));
    });

    setTimeout(() => updateActiveIndex(0), 100);

    window.addEventListener('resize', () => {
      let activeIndex = 0;
      stepButtons.forEach((b, idx) => {
        if (b.style.backgroundColor === 'rgb(249, 249, 249)') {
          activeIndex = idx;
        }
      });
      updateActiveIndex(activeIndex);
    });
  });
</script>

<style>
  .hiw-hatch-pattern {
    background: repeating-linear-gradient(-45deg, #e5e5e5 0, #e5e5e5 1px, transparent 1px, transparent 8px);
    width: 100%;
    height: 100%;
  }

  .hiw-mock-window {
    height: 387.6px;
    box-sizing: border-box;
  }

  .hiw-mock-window-content {
    height: 359.69px;
    box-sizing: border-box;
  }

  @media (max-width: 768px) {
    .hiw-section {
      height: auto !important;
      padding-left: 20px !important;
      padding-right: 20px !important;
    }
    .hiw-row {
      flex-direction: column !important;
      height: auto !important;
      padding: 40px 0 !important;
      width: 100% !important;
    }
    .hiw-left {
      width: 100% !important;
      height: auto !important;
    }
    .hiw-right {
      width: 100% !important;
      aspect-ratio: 1 / 1 !important;
      height: auto !important;
    }
    .hiw-mock-window {
      width: 280px !important;
      height: 280px !important;
      max-width: 100% !important;
    }
    .hiw-mock-window-content {
      height: calc(100% - 27.91px) !important;
    }
    .hiw-left > div:first-child {
      width: 100% !important;
      height: auto !important;
    }
    .hiw-step-btn {
      width: 100% !important;
    }
    .hiw-step-btn .hiw-step-desc p {
      width: 100% !important;
      height: auto !important;
    }
    .hiw-step-text-wrap {
      width: auto !important;
    }
  }
</style>
