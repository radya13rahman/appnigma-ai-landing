---
---
<section class="bg-[#151515] px-section" style="padding-left:120px;padding-right:120px;">
  <div class="border-l border-r border-[#3d3d3d] flex flex-col gap-20 py-20">
    <!-- Heading -->
    <div class="flex flex-col items-center gap-4">
      <div class="bg-[rgba(255,255,255,0.05)] border border-[rgba(255,255,255,0.05)] px-3 py-1 inline-block">
        <span class="font-body font-normal text-[12px] text-[rgba(255,255,255,0.8)] leading-[1.5]">Enterprise-grade by default</span>
      </div>
      <h2 class="font-heading font-medium text-white text-[32px] text-center leading-[1.1]" style="letter-spacing:-1.2px;">Trust isn't a feature flag.</h2>
    </div>
    <!-- Features grid -->
    <div class="border border-[#3d3d3d]">
      <!-- Top image row -->
      <div class="h-[260px] border-b border-[#3d3d3d] overflow-hidden relative">
        <div class="absolute bg-[#1c1c1c] inset-0"></div>
        <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[220px] h-[220px]">
          <img src="/assets/8471d15541b9d1307cac06e2d56e95894261e13d.png" alt="" class="trust-metal w-full h-full object-contain" loading="lazy" />
        </div>
      </div>
      <!-- Feature cards row -->
      <div class="flex">
        <!-- Card 1 -->
        <div class="flex-1 border-r border-[#3d3d3d] flex flex-col">
          <div class="bg-[#262626] border-b border-[#3d3d3d] p-12 flex flex-col gap-4 h-[220px]">
            <h3 class="font-body font-semibold text-white text-[20px] leading-[1.1]" style="letter-spacing:-0.02em;">Security Review ready</h3>
            <p class="font-body font-normal text-[rgba(255,255,255,0.5)] text-[16px] leading-[1.5]">0 PMD violations. Every artifact follows AppExchange Security Review best practices — no back-and-forth with Salesforce reviewers required.</p>
          </div>
          <div class="bg-[#1c1c1c] h-[260px] overflow-hidden relative border-t border-[#3d3d3d]">
            <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-48 h-48">
              <img src="/assets/5041776b6f80ee7654b666512c90c5c8e114c935.svg" alt="" class="w-full h-full" loading="lazy" />
            </div>
          </div>
        </div>
        <!-- Card 2 -->
        <div class="flex-1 border-r border-[#3d3d3d] flex flex-col">
          <div class="bg-[#262626] border-b border-[#3d3d3d] p-12 flex flex-col gap-4 h-[220px]">
            <h3 class="font-body font-semibold text-white text-[20px] leading-[1.1]" style="letter-spacing:-0.02em;">Native architecture</h3>
            <p class="font-body font-normal text-[rgba(255,255,255,0.5)] text-[16px] leading-[1.5]">Real managed package — not a middleware sync or iframe hack. Lives in your customers' Salesforce org the way they expect it to.</p>
          </div>
          <div class="bg-[#1c1c1c] h-[260px] overflow-hidden relative border-t border-[#3d3d3d]">
            <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[200px] h-[200px]">
              <img src="/assets/0fe9cfa3c525c61849339dd5830ce6e81bdafeed.svg" alt="" class="w-full h-full" loading="lazy" />
            </div>
          </div>
        </div>
        <!-- Card 3 -->
        <div class="flex-1 flex flex-col">
          <div class="bg-[#262626] border-b border-[#3d3d3d] p-12 flex flex-col gap-4 h-[220px]">
            <h3 class="font-body font-semibold text-white text-[20px] leading-[1.1]" style="letter-spacing:-0.02em;">You own the IP</h3>
            <p class="font-body font-normal text-[rgba(255,255,255,0.5)] text-[16px] leading-[1.5]">Generated code is 100% yours. Download it, deploy it yourself, never pay us again. No vendor lock-in, no service contract, no perpetual retainer.</p>
          </div>
          <div class="bg-[#1c1c1c] h-[260px] overflow-hidden relative border-t border-[#3d3d3d]">
            <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-60 h-60">
              <img src="/assets/9cf2efb9221f28fe85bb17a3f4df32fb78b0efde.svg" alt="" class="w-full h-full" loading="lazy" />
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Emblem starts larger and shrinks to its resting size when scrolled into view */
  .trust-metal {
    transform: scale(1.6);
    transition: transform 0.9s cubic-bezier(0.22, 1, 0.36, 1);
    will-change: transform;
  }
  .trust-metal.is-in { transform: scale(1); }
  @media (prefers-reduced-motion: reduce) {
    .trust-metal { transform: none; transition: none; }
  }
</style>

<script>
  (function () {
    var el = document.querySelector('.trust-metal');
    if (!el) return;
    if (!('IntersectionObserver' in window)) { el.classList.add('is-in'); return; }
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-in');
          io.unobserve(entry.target);
        }
      });
    }, { threshold: 0.35 });
    io.observe(el);
  })();
</script>
