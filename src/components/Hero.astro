---
---
<section class="hero-section relative bg-white overflow-hidden" style="min-height:836px;">
  <!-- Hero BG image -->
  <div class="absolute inset-0 pointer-events-none">
    <img src="/assets/9c92c14de9348a125c01b7a1e53923e2f9efeaab.png" alt="" class="hero-bg-img absolute inset-0 w-full h-full object-cover object-bottom" fetchpriority="high" />
    <div class="hero-bg-overlay absolute inset-0" style="background:linear-gradient(180deg, rgba(255,255,255,1) 6.68%, rgba(255,255,255,0) 24.28%), linear-gradient(rgba(255,255,255,0) 51.92%, rgba(255,255,255,1) 94.71%)"></div>
  </div>
  <!-- Left gradient overlay -->
  <div class="hero-left-gradient absolute left-0 top-0 h-full pointer-events-none" style="width:893px; background:linear-gradient(to right, white 65%, transparent 100%);"></div>

  <!-- Content -->
  <div class="hero-content relative max-w-[1440px] mx-auto px-section flex items-center" style="padding-left:120px;padding-right:120px;min-height:836px;padding-top:153px;padding-bottom:80px;">
    <div class="flex flex-col gap-16 w-[591px] max-w-full">
      <!-- Heading + description + buttons -->
      <div class="flex flex-col gap-6">
        <h1 class="hero-h1 font-heading font-medium text-[#0a0a0a] leading-[1.1]" style="font-size:64px;letter-spacing:-1.2px;">
          Describe it.<br />Ship it native.<br />In Minutes.
        </h1>
        <p class="font-body font-normal text-[16px] text-[#525252] leading-[1.5]" style="max-width:591px;">
          AI turns your idea into a production-ready managed package for Salesforce, HubSpot, and more. No consultant required.
        </p>
        <div class="flex items-center gap-2">
          <button class="btn-primary font-body font-medium text-[14px] text-white px-3 h-9 rounded-[8px] whitespace-nowrap" style="letter-spacing:-0.14px;">Book a demo</button>
          <button class="btn-secondary font-body font-medium text-[14px] text-[#202b30] px-3 h-9 rounded-[8px] whitespace-nowrap" style="letter-spacing:-0.14px;">Learn More</button>
        </div>
      </div>

      <!-- Social proof / info -->
      <div class="flex flex-col gap-2">
        <!-- Avatars + text -->
        <div class="flex flex-col overflow-hidden py-4">
          <div class="flex items-center gap-6">
            <!-- Overlapping avatars -->
            <div class="flex items-center">
              <div class="w-12 h-12 rounded-full border-[0.96px] border-white overflow-hidden -mr-4 relative z-10" style="background:linear-gradient(to bottom, #d1d1d1, #f9f9f9);">
                <img src="/assets/39921c6e1a55ece00506afb87e09ce5a1f14650b.png" alt="" class="w-full h-full object-cover" />
              </div>
              <div class="w-12 h-12 rounded-full border-[0.96px] border-white overflow-hidden relative" style="background:linear-gradient(to bottom, #d1d1d1, #f9f9f9);">
                <img src="/assets/ef10b07ee57f3b66d85380bf095ffc6d8e2ac0a0.png" alt="" class="w-full h-full object-cover" />
              </div>
            </div>
            <div class="flex flex-col">
              <span class="font-body font-semibold text-[16px] text-[#525252] leading-[1.1]">Built by ex-Salesforce AppExchange engineers</span>
              <span class="font-body font-normal text-[16px] text-[#525252] leading-[1.5]">300+ SaaS integrations shipped</span>
            </div>
          </div>
        </div>
        <!-- CRM badges -->
        <div class="hero-badges flex flex-row flex-nowrap gap-2" style="max-width:591px;">
          <div class="flex items-center gap-2 bg-white border border-[rgba(0,0,0,0.05)] rounded-full px-3 py-2 flex-shrink-0" style="box-shadow:0 0 0 1px rgba(208,208,208,0.05);">
            <span style="display:inline-block;width:20px;height:14px;overflow:hidden;flex-shrink:0;">
              <img src="/assets/8a78f5b5a07ab3a18319e0a602ccf041fe32c461.svg" alt="Salesforce" style="height:14px;width:20px;object-fit:contain;" />
            </span>
            <span class="font-body font-medium text-[14px] text-[#0a0a0a] whitespace-nowrap">Salesforce</span>
          </div>
          <div class="flex items-center gap-2 bg-white border border-[rgba(0,0,0,0.05)] rounded-full px-3 py-2 flex-shrink-0" style="box-shadow:0 0 0 1px rgba(208,208,208,0.05);">
            <span style="display:inline-block;width:12px;height:14px;overflow:hidden;flex-shrink:0;">
              <img src="/assets/hubspot-icon.png" alt="HubSpot" style="height:14px;width:12px;object-fit:contain;" />
            </span>
            <span class="font-body font-medium text-[14px] text-[#0a0a0a] whitespace-nowrap">HubSpot</span>
          </div>
          <div class="flex items-center gap-2 bg-white border border-[rgba(0,0,0,0.05)] rounded-full px-3 py-2 flex-shrink-0" style="box-shadow:0 0 0 1px rgba(208,208,208,0.05);">
            <span class="font-body font-medium text-[14px] text-[#0a0a0a] whitespace-nowrap">Don't see your CRM?</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
