---
---
<section class="bg-[#151515] border border-[#e5e5e5] px-section" style="padding-left:120px;padding-right:120px;">
  <div class="border-l border-r border-[#3d3d3d] flex flex-col gap-20 py-20">
    <!-- Heading -->
    <div class="px-6 flex flex-col gap-4">
      <div class="bg-[rgba(255,255,255,0.05)] border border-[rgba(255,255,255,0.05)] px-3 py-1 inline-flex self-start">
        <span class="font-body font-normal text-[12px] text-[rgba(255,255,255,0.5)] leading-[1.5]">Platforms</span>
      </div>
      <h2 class="font-heading font-medium text-white text-[32px] leading-[1.1] whitespace-nowrap" style="letter-spacing:-1.2px;">One generator. Every CRM your customers run.</h2>
    </div>
    <!-- CRM cards -->
    <div class="flex flex-col gap-4">
      <div class="border border-[#3d3d3d] grid grid-cols-2">
        <!-- Salesforce -->
        <div class="border-r border-[#3d3d3d] flex flex-col">
          <div class="h-[260px] bg-[#1c1c1c] border-b border-[#3d3d3d] relative overflow-hidden">
            <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[200px] h-[200px]">
              <img src="/assets/d62fc690d3faed897a2c1952523a7167b76b75f5.png" alt="Salesforce" class="w-full h-full object-contain" loading="lazy" />
            </div>
          </div>
          <div class="bg-[#1c1c1c] border-b border-[#3d3d3d] px-12 py-6 flex items-center justify-between h-[74px]">
            <div class="flex items-center gap-4">
              <span class="font-body font-semibold text-white text-[20px] leading-[1.1]" style="letter-spacing:-0.02em;">Salesforce</span>
              <span class="bg-[#313a18] border border-[#7f924b] px-2 py-1 font-body font-normal text-white text-[14px]">Available</span>
            </div>
            <button class="btn-secondary font-body font-medium text-[14px] text-[#202b30] px-3 h-9 rounded-[8px] whitespace-nowrap" style="letter-spacing:-0.14px;">See Details</button>
          </div>
          <div class="bg-[#262626] border-b border-[#3d3d3d] p-12 flex flex-col gap-4">
            <h3 class="font-body font-semibold text-white text-[20px] leading-[1.1]" style="letter-spacing:-0.02em;">AppExchange ready</h3>
            <p class="font-body font-normal text-[rgba(255,255,255,0.5)] text-[16px] leading-[1.5]">Managed packages with Security Review embedded out of the box.</p>
          </div>
        </div>
        <!-- HubSpot -->
        <div class="flex flex-col">
          <div class="h-[260px] bg-[#1c1c1c] border-b border-[#3d3d3d] relative overflow-hidden">
            <div class="absolute left-1/2 top-[31px] -translate-x-1/2 w-[200px] h-[200px]">
              <img src="/assets/7d1f3ed13e3eb2333f0225c8d40d265cf4c78753.png" alt="HubSpot" class="w-full h-full object-contain" loading="lazy" />
            </div>
          </div>
          <div class="bg-[#1c1c1c] border-b border-[#3d3d3d] px-12 py-6 flex items-center h-[74px]">
            <div class="flex items-center gap-4">
              <span class="font-body font-semibold text-white text-[20px] leading-[1.1]" style="letter-spacing:-0.02em;">HubSpot</span>
              <span class="bg-[#333] border border-[#737373] px-2 py-1 font-body font-normal text-white text-[14px]">Q3 2026</span>
            </div>
          </div>
          <div class="bg-[#262626] p-12 flex-1 flex flex-col gap-4">
            <h3 class="font-body font-semibold text-white text-[20px] leading-[1.1]" style="letter-spacing:-0.02em;">Native marketplace</h3>
            <p class="font-body font-normal text-[rgba(255,255,255,0.5)] text-[16px] leading-[1.5]">Marketplace apps with OAuth and native CRM cards.</p>
          </div>
        </div>
      </div>
      <!-- Don't see your CRM row -->
      <div class="bg-[#262626] border border-[#3d3d3d] px-12 py-6 flex items-center justify-between">
        <div class="flex flex-col gap-2">
          <h3 class="font-heading font-medium text-white text-[20px] leading-[1.1]" style="letter-spacing:-0.02em;">Don't see your CRM?</h3>
          <p class="font-body font-normal text-[rgba(255,255,255,0.5)] text-[16px] leading-[1.5]">Tell us which platform to support next.</p>
        </div>
        <button class="btn-secondary font-body font-medium text-[14px] text-[#202b30] px-3 h-9 rounded-[8px] whitespace-nowrap" style="letter-spacing:-0.14px;">Contact Us</button>
      </div>
    </div>
  </div>
</section>
