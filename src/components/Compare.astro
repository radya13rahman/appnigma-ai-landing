---
---
<section class="bg-white border-b border-[#e5e5e5] px-section" style="padding-left:120px;padding-right:120px;">
  <div class="border-l border-r border-[#ebebeb] py-20 flex flex-col gap-12">
    <!-- Heading -->
    <div class="px-6 flex flex-col gap-4">
      <div class="border border-[#e5e5e5] bg-white px-3 py-1 inline-flex self-start">
        <span class="font-body font-normal text-[12px] text-[#525252] leading-[1.5]">Compare</span>
      </div>
      <h2 class="font-heading font-medium text-[#151515] text-[40px] leading-[1.1]" style="letter-spacing:-1.2px;">Compared to the alternatives.</h2>
      <p class="font-body font-normal text-[16px] text-[#525252] leading-[1.5]">Faster than consultants. Cleaner than middleware. Less painful than DIY.</p>
    </div>

    <!-- Cards row -->
    <div class="flex gap-4 px-6 overflow-x-auto">
      <!-- Appnigma AI card -->
      <div class="bg-white border border-[#151515] rounded-none flex flex-col p-6 gap-4 flex-shrink-0" style="width:280px;">
        <div class="bg-[#151515] text-white px-2 py-1 self-start flex items-center gap-2">
          <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor"><path d="M8 8a4 4 0 1 0 0-8 4 4 0 0 0 0 8zm-6 8a6 6 0 1 1 12 0H2z"/></svg>
          <span class="font-body font-medium text-[12px]">Yours</span>
        </div>
        <p class="font-body font-medium text-[16px] text-[#0a0a0a] leading-[1.4]">IP ownership. Your code, your terms, no rent forever.</p>
        <div class="bg-[#fafafa] border border-[#e5e5e5] rounded-[6px] overflow-hidden mt-2">
          <div class="flex items-center gap-1 p-2 border-b border-[#e5e5e5] bg-white">
            <div class="w-1.5 h-1.5 rounded-full bg-[#ee6d5e]"></div>
            <div class="w-1.5 h-1.5 rounded-full bg-[#f3bf4a]"></div>
            <div class="w-1.5 h-1.5 rounded-full bg-[#5dc753]"></div>
            <span class="font-mono text-[8px] text-[#7d7d7d] ml-2">Appnigma.ai</span>
          </div>
          <div class="h-20"></div>
        </div>
      </div>
      <!-- Fast card -->
      <div class="bg-white border border-[#e5e5e5] rounded-none flex flex-col p-6 gap-4 flex-shrink-0" style="width:280px;">
        <div class="bg-[#151515] text-white px-2 py-1 self-start flex items-center gap-2">
          <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0L6 6H0l5 4-2 6 5-4 5 4-2-6 5-4h-6z"/></svg>
          <span class="font-body font-medium text-[12px]">Fast</span>
        </div>
        <p class="font-body font-medium text-[16px] text-[#0a0a0a] leading-[1.4]">Days, not quarters. While consultants scope, we deliver.</p>
        <div class="bg-[#fafafa] border border-[#e5e5e5] rounded-[6px] overflow-hidden mt-2">
          <div class="flex items-center gap-1 p-2 border-b border-[#e5e5e5] bg-white">
            <div class="w-1.5 h-1.5 rounded-full bg-[#ee6d5e]"></div>
            <div class="w-1.5 h-1.5 rounded-full bg-[#f3bf4a]"></div>
            <div class="w-1.5 h-1.5 rounded-full bg-[#5dc753]"></div>
            <span class="font-mono text-[8px] text-[#7d7d7d] ml-2">Appnigma.ai</span>
          </div>
          <div class="h-20"></div>
        </div>
      </div>
      <!-- Native card -->
      <div class="bg-white border border-[#e5e5e5] rounded-none flex flex-col p-6 gap-4 flex-shrink-0" style="width:280px;">
        <div class="bg-[#151515] text-white px-2 py-1 self-start flex items-center gap-2">
          <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor"><path d="M10 2H6a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2h4a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2z"/></svg>
          <span class="font-body font-medium text-[12px]">Native</span>
        </div>
        <p class="font-body font-medium text-[16px] text-[#0a0a0a] leading-[1.4]">Real managed package. Lives inside Salesforce the way it should.</p>
        <div class="bg-[#fafafa] border border-[#e5e5e5] rounded-[6px] overflow-hidden mt-2">
          <div class="flex items-center gap-1 p-2 border-b border-[#e5e5e5] bg-white">
            <div class="w-1.5 h-1.5 rounded-full bg-[#ee6d5e]"></div>
            <div class="w-1.5 h-1.5 rounded-full bg-[#f3bf4a]"></div>
            <div class="w-1.5 h-1.5 rounded-full bg-[#5dc753]"></div>
            <span class="font-mono text-[8px] text-[#7d7d7d] ml-2">Appnigma.ai</span>
          </div>
          <div class="h-20"></div>
        </div>
      </div>
      <!-- Honest card -->
      <div class="bg-white border border-[#e5e5e5] rounded-none flex flex-col p-6 gap-4 flex-shrink-0" style="width:280px;">
        <div class="bg-[#151515] text-white px-2 py-1 self-start flex items-center gap-2">
          <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor"><path d="M8 1a7 7 0 1 0 0 14A7 7 0 0 0 8 1zm0 3a1 1 0 1 1 0 2 1 1 0 0 1 0-2zm0 3h1v5H7V7h1z"/></svg>
          <span class="font-body font-medium text-[12px]">Honest</span>
        </div>
        <p class="font-body font-medium text-[16px] text-[#0a0a0a] leading-[1.4]">Fixed price, scoped to your build. No retainers, no surprise invoices.</p>
        <div class="bg-[#fafafa] border border-[#e5e5e5] rounded-[6px] overflow-hidden mt-2">
          <div class="flex items-center gap-1 p-2 border-b border-[#e5e5e5] bg-white">
            <div class="w-1.5 h-1.5 rounded-full bg-[#ee6d5e]"></div>
            <div class="w-1.5 h-1.5 rounded-full bg-[#f3bf4a]"></div>
            <div class="w-1.5 h-1.5 rounded-full bg-[#5dc753]"></div>
            <span class="font-mono text-[8px] text-[#7d7d7d] ml-2">Appnigma.ai</span>
          </div>
          <div class="h-20"></div>
        </div>
      </div>
    </div>

    <!-- Comparison Table -->
    <div class="px-0 compare-table-wrap">
      <table class="w-full border-collapse border border-[#e5e5e5]" style="table-layout:fixed;">
        <thead>
          <tr>
            <th class="text-left p-4 font-body font-normal text-[14px] text-[#525252] border border-[#e5e5e5] bg-white" style="width:25%;">Capability</th>
            <th class="p-4 border border-[#e5e5e5] bg-[#151515]" style="width:18.75%;">
              <div class="text-white font-heading font-medium text-[16px]">Appnigma AI</div>
              <div class="text-[rgba(255,255,255,0.5)] font-body text-[12px] mt-0.5">Tailored to your budget</div>
            </th>
            <th class="p-4 border border-[#e5e5e5] bg-white" style="width:18.75%;">
              <div class="font-body font-medium text-[16px] text-[#0a0a0a]">Consultants</div>
              <div class="text-[#737373] font-body text-[12px] mt-0.5">from $150K/yr</div>
            </th>
            <th class="p-4 border border-[#e5e5e5] bg-white" style="width:18.75%;">
              <div class="font-body font-medium text-[16px] text-[#0a0a0a]">Middleware</div>
              <div class="text-[#737373] font-body text-[12px] mt-0.5">from $30K/yr</div>
            </th>
            <th class="p-4 border border-[#e5e5e5] bg-white" style="width:18.75%;">
              <div class="font-body font-medium text-[16px] text-[#0a0a0a]">DIY</div>
              <div class="text-[#737373] font-body text-[12px] mt-0.5">from $95K/yr</div>
            </th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td class="p-4 border border-[#e5e5e5] font-body text-[14px] text-[#0a0a0a] flex items-center gap-2">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="#737373"><path d="M10 2H6a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2h4a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2z"/></svg>
              Native managed package
            </td>
            <td class="p-4 border border-[#e5e5e5] text-center bg-[#f9f9f9]"><span class="check-circle mx-auto"><svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6l3 3 5-5" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span></td>
            <td class="p-4 border border-[#e5e5e5] text-center font-body text-[14px] text-[#525252]">-</td>
            <td class="p-4 border border-[#e5e5e5] text-center font-body text-[14px] text-[#525252]">-</td>
            <td class="p-4 border border-[#e5e5e5] text-center font-body text-[14px] text-[#525252]">partial</td>
          </tr>
          <tr>
            <td class="p-4 border border-[#e5e5e5] font-body text-[14px] text-[#0a0a0a] flex items-center gap-2">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="#737373"><path d="M8 1a7 7 0 1 0 0 14A7 7 0 0 0 8 1z"/></svg>
              Security Review ready
            </td>
            <td class="p-4 border border-[#e5e5e5] text-center bg-[#f9f9f9]"><span class="check-circle mx-auto"><svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6l3 3 5-5" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span></td>
            <td class="p-4 border border-[#e5e5e5] text-center font-body text-[14px] text-[#525252]">partial</td>
            <td class="p-4 border border-[#e5e5e5] text-center font-body text-[14px] text-[#525252]">-</td>
            <td class="p-4 border border-[#e5e5e5] text-center font-body text-[14px] text-[#525252]">-</td>
          </tr>
          <tr>
            <td class="p-4 border border-[#e5e5e5] font-body text-[14px] text-[#0a0a0a] flex items-center gap-2">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="#737373"><circle cx="8" cy="8" r="6"/></svg>
              AppExchange listing
            </td>
            <td class="p-4 border border-[#e5e5e5] text-center bg-[#f9f9f9]"><span class="check-circle mx-auto"><svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6l3 3 5-5" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span></td>
            <td class="p-4 border border-[#e5e5e5] text-center"><span class="check-circle mx-auto"><svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6l3 3 5-5" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span></td>
            <td class="p-4 border border-[#e5e5e5] text-center font-body text-[14px] text-[#525252]">-</td>
            <td class="p-4 border border-[#e5e5e5] text-center font-body text-[14px] text-[#525252]">-</td>
          </tr>
          <tr>
            <td class="p-4 border border-[#e5e5e5] font-body text-[14px] text-[#0a0a0a] flex items-center gap-2">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="#737373"><path d="M8 0L6 6H0l5 4-2 6 5-4 5 4-2-6 5-4h-6z"/></svg>
              Days, not months
            </td>
            <td class="p-4 border border-[#e5e5e5] text-center bg-[#f9f9f9]"><span class="check-circle mx-auto"><svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6l3 3 5-5" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span></td>
            <td class="p-4 border border-[#e5e5e5] text-center font-body text-[14px] text-[#525252]">-</td>
            <td class="p-4 border border-[#e5e5e5] text-center"><span class="check-circle mx-auto"><svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6l3 3 5-5" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span></td>
            <td class="p-4 border border-[#e5e5e5] text-center font-body text-[14px] text-[#525252]">-</td>
          </tr>
          <tr>
            <td class="p-4 border border-[#e5e5e5] font-body text-[14px] text-[#0a0a0a] flex items-center gap-2">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="#737373"><path d="M10 2H6a2 2 0 0 0-2 2v8a2 2 0 0 0 2 2h4a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2z"/></svg>
              You own the IP
            </td>
            <td class="p-4 border border-[#e5e5e5] text-center bg-[#f9f9f9]"><span class="check-circle mx-auto"><svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6l3 3 5-5" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span></td>
            <td class="p-4 border border-[#e5e5e5] text-center font-body text-[14px] text-[#525252]">-</td>
            <td class="p-4 border border-[#e5e5e5] text-center"><span class="check-circle mx-auto"><svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6l3 3 5-5" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span></td>
            <td class="p-4 border border-[#e5e5e5] text-center"><span class="check-circle mx-auto"><svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6l3 3 5-5" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span></td>
          </tr>
          <tr>
            <td class="p-4 border border-[#e5e5e5] font-body text-[14px] text-[#0a0a0a] flex items-center gap-2">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="#737373"><rect x="2" y="4" width="12" height="8" rx="1"/><path d="M5 4V3a3 3 0 0 1 6 0v1"/></svg>
              No service contract
            </td>
            <td class="p-4 border border-[#e5e5e5] text-center bg-[#f9f9f9]"><span class="check-circle mx-auto"><svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6l3 3 5-5" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span></td>
            <td class="p-4 border border-[#e5e5e5] text-center font-body text-[14px] text-[#525252]">-</td>
            <td class="p-4 border border-[#e5e5e5] text-center"><span class="check-circle mx-auto"><svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6l3 3 5-5" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span></td>
            <td class="p-4 border border-[#e5e5e5] text-center"><span class="check-circle mx-auto"><svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 6l3 3 5-5" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span></td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</section>
