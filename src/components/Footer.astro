---
---
<footer class="bg-white border-t border-[#e5e5e5] px-section" style="padding-left:120px;padding-right:120px;">
  <div class="flex flex-col gap-12 pt-16 pb-0">
    <!-- Top: brand + links -->
    <div class="flex items-start justify-between">
      <!-- Brand column -->
      <div class="footer-brand-col flex flex-col gap-9 relative" style="width:358px;">
        <a href="#" class="flex items-center gap-2">
          <img src="/assets/d4fa65061f8d343fe1b5f7058e5c694dca4a764b.png" alt="Appnigma AI" class="w-6 h-6 rounded-[4.5px] object-contain" loading="lazy" />
          <span class="font-heading font-medium text-[16px] text-[#0a0a0a] leading-[1.5]" style="letter-spacing:-0.02em;">Appnigma AI</span>
        </a>
        <p class="font-body font-normal text-[14px] text-[#737373] leading-[1.5]" style="width:260px;">Native managed packages for B2B SaaS. Generated, not consulted.</p>
        <button class="btn-primary font-body font-medium text-[14px] text-white px-3 h-8 rounded-[8px] self-start whitespace-nowrap" style="letter-spacing:-0.14px;">Book a demo</button>
      </div>
      <!-- Nav columns -->
      <div class="flex items-start gap-6">
        <!-- Platform -->
        <div class="flex flex-col gap-3 w-40">
          <span class="font-body font-normal text-[14px] text-[#0a0a0a] leading-[1.4]">Platform</span>
          <a href="#" class="font-body font-normal text-[14px] text-[#737373] leading-[1.4] hover:text-[#0a0a0a] transition-colors">Salesforce</a>
          <a href="#" class="font-body font-normal text-[14px] text-[#737373] leading-[1.4] hover:text-[#0a0a0a] transition-colors">HubSpot</a>
          <a href="#" class="font-body font-normal text-[14px] text-[#737373] leading-[1.4] hover:text-[#0a0a0a] transition-colors">Pricing</a>
        </div>
        <!-- Customers -->
        <div class="flex flex-col gap-3 w-40">
          <span class="font-body font-normal text-[14px] text-[#0a0a0a] leading-[1.4]">Customers</span>
          <a href="#" class="font-body font-normal text-[14px] text-[#737373] leading-[1.4] hover:text-[#0a0a0a] transition-colors">All stories</a>
          <a href="#" class="font-body font-normal text-[14px] text-[#737373] leading-[1.4] hover:text-[#0a0a0a] transition-colors">Salesforce stories</a>
          <a href="#" class="font-body font-normal text-[14px] text-[#737373] leading-[1.4] hover:text-[#0a0a0a] transition-colors">HubSpot stories</a>
        </div>
        <!-- Resources -->
        <div class="flex flex-col gap-3 w-40">
          <span class="font-body font-normal text-[14px] text-[#0a0a0a] leading-[1.4]">Resources</span>
          <a href="#" class="font-body font-normal text-[14px] text-[#737373] leading-[1.4] hover:text-[#0a0a0a] transition-colors">Blog</a>
          <a href="#" class="font-body font-normal text-[14px] text-[#737373] leading-[1.4] hover:text-[#0a0a0a] transition-colors">Docs</a>
          <a href="#" class="font-body font-normal text-[14px] text-[#737373] leading-[1.4] hover:text-[#0a0a0a] transition-colors">Changelog</a>
        </div>
        <!-- Company -->
        <div class="flex flex-col gap-3 w-40">
          <span class="font-body font-normal text-[14px] text-[#0a0a0a] leading-[1.4]">Company</span>
          <a href="#" class="font-body font-normal text-[14px] text-[#737373] leading-[1.4] hover:text-[#0a0a0a] transition-colors">About</a>
          <a href="#" class="font-body font-normal text-[14px] text-[#737373] leading-[1.4] hover:text-[#0a0a0a] transition-colors">Careers</a>
          <a href="#" class="font-body font-normal text-[14px] text-[#737373] leading-[1.4] hover:text-[#0a0a0a] transition-colors">Contact</a>
        </div>
      </div>
    </div>
    <!-- Bottom: legal -->
    <div class="border-t border-[#e5e5e5] flex items-center justify-between py-6">
      <span class="font-body font-normal text-[12px] text-[#737373] leading-[1.5]">© 2026 Appnigma AI, Inc. All rights reserved.</span>
      <div class="flex items-center gap-6">
        <a href="#" class="font-body font-normal text-[14px] text-[#737373] leading-[1.5] hover:text-[#0a0a0a] transition-colors">Term of Use</a>
        <a href="#" class="font-body font-normal text-[14px] text-[#737373] leading-[1.5] hover:text-[#0a0a0a] transition-colors">Privacy Policy</a>
      </div>
    </div>
  </div>
</footer>
